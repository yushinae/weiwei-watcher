# 复制本文件为 .env 并填入你的密钥。
# .env 已被 .gitignore 忽略，不会提交。修改 .env 后需要重启 dev server 才生效。

# ── Bybit（头寸可视化 / 实时持仓）──────────────────────────────────────────────
# 请务必使用「只读」API key（不要开提现/下单权限）。
# 注意：VITE_ 变量会被打进前端包，密钥会出现在浏览器里——仅用于你自己的本地终端，
# 切勿把带密钥的构建产物部署到共享/公开环境。
VITE_BYBIT_API_KEY=
VITE_BYBIT_API_SECRET=

# ── Deribit（可选，目前期权行情走公有 WS，无需密钥）─────────────────────────────
VITE_DERIBIT_API_KEY=
VITE_DERIBIT_API_SECRET=

# ── 后端代理目标（可选；默认 http://localhost:8787）──────────────────────────────
# API_PROXY_TARGET=http://localhost:8787
