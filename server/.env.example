PORT=8787
DATABASE_URL=postgresql://postgres:postgres@db:5432/nexus
CORS_ORIGIN=http://localhost:3000

# 启用交易所采集器（建议本地开发打开）
ENABLE_COLLECTORS=true

# 环境选择：testnet / mainnet
BYBIT_ENV=testnet
DERIBIT_ENV=testnet

# 下面四项请你在本地自行填入（不要发到聊天里，不要提交到 git）
BYBIT_API_KEY=
BYBIT_API_SECRET=
DERIBIT_CLIENT_ID=
DERIBIT_CLIENT_SECRET=

# 可选：手动指定订阅的 Bybit 期权 symbol（逗号分隔）。留空则只连接不订阅具体期权。
BYBIT_SYMBOLS=

# 可选：bootstrap 标的
BYBIT_BASE_COINS=BTC,ETH
DERIBIT_CURRENCIES=BTC,ETH

